# Copy this file to .env and fill in real values.
# NEVER commit .env — it's in .gitignore.

# --- Sanctions oracle (on-chain, NO API KEY NEEDED) ------------------
# Sanctions screening uses the Chainalysis on-chain oracle — a public
# smart contract that needs no API key and no signup. These two are
# OPTIONAL overrides with sensible defaults; you can leave them blank.
#
# Override the RPC only if the default public endpoint rate-limits you
# under load (any Ethereum mainnet RPC works — e.g. an Alchemy/Infura URL).
SANCTIONS_ORACLE_RPC_URL=
# Override the oracle contract address only if you deliberately target a
# different chain's deployment (default is Ethereum mainnet).
SANCTIONS_ORACLE_ADDRESS=

# --- Companies House (free) -------------------------------------------
# Key from https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# --- Tempo / MPP ------------------------------------------------------
# Wallet that receives payments. Valid 0x + 40 hex chars.
MPP_RECIPIENT_ADDRESS=

# ⚠️ MAINNET CURRENCY ADDRESS — must be the LIVE-MODE pathUSD/USDC token
# from the Stripe Dashboard "Run live mode transactions" section.
# Do NOT use 0x20c0...0000 (that's the TESTNET token — the server will
# refuse to start with it when TEMPO_TESTNET is not 'true').
TEMPO_CURRENCY_ADDRESS=

# Network selector. 'false' = mainnet. Set explicitly.
TEMPO_TESTNET=false

# Root-of-trust for payment challenge binding. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# On a hosting platform, set this in the platform's env/secrets UI, not here.
MPP_SECRET_KEY=

# Optional: local port (default 3000). Hosting platforms set this themselves.
PORT=3000

# --- Attestation (recommended for production) -------------------------
# Ed25519 private key (PKCS8 PEM) used to cryptographically SIGN every
# response, turning it into verifiable evidence for auditors. If unset,
# the API still works but returns UNSIGNED responses (flagged as such).
# Generate one (run locally, once), then paste the PRIVATE block here:
#   node -e "const c=require('crypto');const{publicKey,privateKey}=c.generateKeyPairSync('ed25519');console.log(privateKey.export({type:'pkcs8',format:'pem'}))"
# On a hosting platform, paste it into the secrets UI. Multi-line is fine;
# literal \n sequences are also accepted.
ATTESTATION_PRIVATE_KEY=
